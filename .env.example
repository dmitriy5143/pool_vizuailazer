# Minimal config. All regular demo defaults live in server/config.js and docker-compose.yml.
# Without a key, DEMO_GENERATION_MODE=auto falls back to mock mode.
OPENROUTER_API_KEY=

# Optional overrides, normally not needed:
# DEMO_GENERATION_MODE=auto
# OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image
# OPENROUTER_PLACEMENT_MODEL=google/gemini-2.5-flash
# OPENROUTER_VALIDATION_MODEL=google/gemini-2.5-flash
# MAX_VARIANT_COUNT=20
# APP_PORT=5177
